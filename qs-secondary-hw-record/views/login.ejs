<section class="login-panel">
  <div class="login-card">
    <div class="text-center mb-4">
      <img src="/img/qslogo.png" alt="Qs logo" class="login-logo">
      <h1 class="h4 mt-3 mb-1">Qs Secondary HW Record</h1>
      <p class="text-secondary mb-0">Admin homework checking system</p>
    </div>

    <form method="post" action="/login" class="vstack gap-3">
      <div>
        <label class="form-label">Username</label>
        <input class="form-control form-control-lg" type="text" name="username" value="Admin" required autofocus>
      </div>
      <div>
        <label class="form-label">Password</label>
        <input class="form-control form-control-lg" type="password" name="password" required>
      </div>
      <button class="btn btn-primary btn-lg w-100">Sign In</button>
    </form>
  </div>
</section>
